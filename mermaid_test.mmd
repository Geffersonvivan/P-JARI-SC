flowchart TD
    Start([Inicio Novo Recurso Submetido pelo Assessor]) --> F1

    subgraph Fase1 [Fase 1 Extracao Cognitiva e Tabela Basica]
        F1(Leitura do PDF) --> ExtraiMetadados{LLM extrai 5 perguntas}
        ExtraiMetadados -->|Placa AIT Data Infracao| F2
        ExtraiMetadados -->|Auto de Infracao Incompleto| F2_Falha(Nulidade por Falta de Peca)
    end

    F2_Falha -.-> F5_Conclusora

    subgraph Fase2 [Fase 2 Validacao Formal Fixa Regex]
        F2(Valida Conformidade do AIT) --> RegexCheck{Passou nas Regras Restritas}
        RegexCheck -->|Sim| F3
        RegexCheck -->|Nao Renavam Divergente| RejeitaFormal(Requer Validacao Humana)
    end

    RejeitaFormal -.-> F3

    subgraph Fase3 [Fase 3 Motor Matematico Ordem Publica]
        F3(Submete Datas a JariMath) --> CheckPrejudicialidade

        CheckPrejudicialidade -->|Verifica Tempestividade| EIntempestivo{Passou do Prazo de Defesa}
        EIntempestivo -->|Sim| Intempestivo[Recurso Intempestivo]
        EIntempestivo -->|Nao| VerificaPP

        VerificaPP -->|Prescricao Punitiva| EPPP{Diferenca Maior que 5 Anos}
        EPPP -->|Sim| PPP[Prescricao Punitiva do Estado]
        EPPP -->|Nao| VerificaPI

        VerificaPI -->|Prescricao Intercorrente| EPI{Julgamento Ultrapassa Aniversario de 3 Anos}
        EPI -->|Sim| PI[Prescricao Intercorrente]
        EPI -->|Nao| VerificaDecadencia

        VerificaDecadencia -->|Decadencia CTB| EDecadente{Passou limite de dias da Infracao}
        EDecadente -->|Sim| Decadente[Decadencia do Direito de Punir]
        EDecadente -->|Nao| F4
    end

    Intempestivo --> GatilhoIndeferidoLiminar{Gatilho Recurso Nao Conhecido}
    PPP --> GatilhoDeferidoLiminar{Gatilho Extincao da Punibilidade}
    PI --> GatilhoDeferidoLiminar
    Decadente --> GatilhoDeferidoLiminar

    GatilhoIndeferidoLiminar -->|Merito Prejudicado| F5_Conclusora
    GatilhoDeferidoLiminar -->|Merito Prejudicado| F5_Conclusora

    subgraph Fase4 [Fase 4 Recuperacao Jurisprudencial Vertex AI]
        F4(Busca Semantica no Inventario Google) --> BuscaLegis(Localiza Regras CTB e CONTRAN)
        BuscaLegis --> ExtraiTesesDefense(LLM Isola Teses do Infrator)
        ExtraiTesesDefense --> F5
    end

    subgraph Fase5 [Fase 5 Motor de Julgamento Gemini Flash]
        F5(Redacao do Parecer) --> AnaliseMerito{Avaliacao de Merito das Teses da Defesa}
        AnaliseMerito -->|Tese Infrutifera| AcolhimentoB(Opcao B Mantem Presuncao)
        AnaliseMerito -->|Tese Factual com Prova| AcolhimentoA(Opcao A Acolhe Falha do Orgao Autuador)
        
        AcolhimentoB --> TerminaIndeferido(Gera minuta de INDEFERIMENTO)
        AcolhimentoA --> TerminaDeferido(Gera minuta de DEFERIMENTO)
    end

    TerminaIndeferido --> F5_Conclusora
    TerminaDeferido --> F5_Conclusora

    subgraph Fase6 [Fase 6 Camada de Blindagem e Auditoria Reversa]
        F5_Conclusora(Compila Texto Final) --> AuditoriaReversa(LLM Revisor Cruza Matematica e Texto)
        AuditoriaReversa --> ChecaErro{Ha Erro ou Alucinacao Material}
        ChecaErro -->|Sim| Bloqueia(Retem Entrega Alerta Assessor)
        ChecaErro -->|Nao| Conclui
    end

    Bloqueia --> EndIndef([Fim Interceptado P Jari])
    Conclui --> ResultadoFinal{Resultado}
    
    ResultadoFinal -->|Recurso Nao Conhecido| FimIndeferido([PROCESSO INDEFERIDO E MULTA MANTIDA])
    ResultadoFinal -->|Prescricao ou Falha Material| FimDeferido([PROCESSO DEFERIDO E MULTA CANCELADA])
